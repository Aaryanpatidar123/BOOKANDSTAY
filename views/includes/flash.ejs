<% if (typeof success !== 'undefined' && success && success.length) { %>
<div class="alert alert-success  alert-dismissible fade show col-6 offset-3" role="alert">
    <%= Array.isArray(success) ? success[0] : success %>
<button 
    type="button" 
    class="btn-close" 
    data-bs-dismiss="alert" 
    aria-label="close"
></button>
</div>
<% } %>

<% if (typeof error !== 'undefined' && error && error.length) { %>
<div class="alert alert-danger  alert-dismissible fade show col-6 offset-3" role="alert">
    <%= Array.isArray(error) ? error[0] : error %>
<button 
    type="button" 
    class="btn-close" 
    data-bs-dismiss="alert" 
    aria-label="close"
></button>
</div>
<% } %>