<% layout('layouts/boilerplate')%>

<style>
  .carousel-container {
    max-width: 100%;
    position: relative;
    width: 100%;
    background: #f5f5f5;
  }

  .carousel {
    position: relative;
    width: 100%;
  }

  .carousel-inner {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    background: #000;
  }

  .carousel-item {
    height: 400px;
    background: #f5f5f5;
    position: relative;
  }

  .carousel-item img {
    height: 100%;
    width: 100%;
    object-fit: contain;
    display: block;
  }

  .carousel-control-prev,
  .carousel-control-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 50px;
    height: 50px;
    background: rgba(102, 126, 234, 0.8);
    border-radius: 50%;
    border: none;
    z-index: 10;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .carousel-control-prev:hover,
  .carousel-control-next:hover {
    background: rgba(102, 126, 234, 1);
    transform: translateY(-50%) scale(1.1);
  }

  .carousel-control-prev {
    left: 15px;
  }

  .carousel-control-next {
    right: 15px;
  }

  .carousel-control-prev-icon,
  .carousel-control-next-icon {
    display: inline-block;
    width: 20px;
    height: 20px;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    color: white;
  }

  .carousel-control-prev-icon::before {
    content: "‹";
    font-size: 1.5rem;
    color: white;
    font-weight: bold;
  }

  .carousel-control-next-icon::before {
    content: "›";
    font-size: 1.5rem;
    color: white;
    font-weight: bold;
  }

  .carousel-indicators {
    position: absolute;
    bottom: 15px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 5;
  }

  .carousel-indicators button {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: none;
    background-color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .carousel-indicators button:hover {
    background-color: rgba(255, 255, 255, 0.8);
  }

  .carousel-indicators button.active {
    background-color: #667eea;
    width: 14px;
    height: 14px;
  }

  .photo-count {
    position: absolute;
    top: 15px;
    right: 15px;
    background: rgba(0, 0, 0, 0.7);
    color: white;
    padding: 8px 12px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.9rem;
    z-index: 5;
  }
</style>

    <div class="card ary_card">
        <h3>
            <%= listing.title %>
        </h3>
</div>

    <div class="card listing-card mb-4 mt-4">
        <!-- Auto-sliding Carousel -->
        <% if(listing.images && listing.images.length > 0) { %>
          <div class="carousel-container">
            <div id="listingCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="3000">
              <div class="carousel-inner">
                <% listing.images.forEach((img, idx) => { %>
                  <div class="carousel-item <% if(idx === 0) { %>active<% } %>">
                    <img src="<%= img.url %>" class="d-block w-100" alt="Room photo <%= idx + 1 %>">
                  </div>
                <% }) %>
              </div>

              <% if(listing.images.length > 1) { %>
                <button class="carousel-control-prev" type="button" data-bs-target="#listingCarousel" data-bs-slide="prev">
                  <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                  <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#listingCarousel" data-bs-slide="next">
                  <span class="carousel-control-next-icon" aria-hidden="true"></span>
                  <span class="visually-hidden">Next</span>
                </button>
              <% } %>

              <div class="carousel-indicators">
                <% listing.images.forEach((img, idx) => { %>
                  <button type="button" data-bs-target="#listingCarousel" data-bs-slide-to="<%= idx %>" <% if(idx === 0) { %>class="active" aria-current="true"<% } %> aria-label="Slide <%= idx + 1 %>"></button>
                <% }) %>
              </div>

              <div class="photo-count"><i class="fas fa-images"></i> <%= listing.images.length %>/10</div>
            </div>
          </div>
        <% } else if(listing.image && listing.image.url) { %>
          <!-- Fallback to old image format -->
          <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 400px; object-fit:cover; border-radius: 12px; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);" />
        <% } else { %>
          <img src="https://via.placeholder.com/800x450?text=No+Image" class="card-img-top" alt="listing_image" style="height: 400px; object-fit:cover; border-radius: 12px; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);" />
        <% } %>

        <div class="card-body">
            <p class="card-text">Owned by <i>
                <% if (listing.owner) { %>
                    <%= listing.owner.username ? listing.owner.username : (listing.owner.email ? listing.owner.email : 'Owner') %>
                <% } else { %>
                    Unknown
                <% } %>
            </i></p>
            <p class="card-text"> <%= listing.description %></p>
            <p class="card-text">
                <b>Price:</b> &#8377;<%= (listing.price != null && listing.price !== '') ? Number(listing.price).toLocaleString('en-IN') : 'N/A' %>/night
            </p>
           
            <p class="card-text">
                <b>Location:</b> <%= listing.location %> &nbsp; <b>Country:</b> <%= listing.country %>
            </p>
            <p class="card-text"><b>Category:</b> <%= listing.category %> </p>
        </div>
         <div class="mt-3">
                <% if(currUser && listing.owner && ( (listing.owner._id && listing.owner._id.toString() !== currUser._id.toString()) || (typeof listing.owner === 'string' && listing.owner !== currUser._id.toString()) ) ) { %>
                    <a href="/bookings/new/<%= listing._id %>" class="btn btn-primary">Book Now</a>
                <% } else if (!currUser) { %>
                    <a href="/login" class="btn btn-secondary">Sign in to Book</a>
                <% } %>
            </div>
    </div>


        <br />
        <% if(currUser && ( (listing.owner && ((listing.owner._id && listing.owner._id.toString() === currUser._id.toString()) || (typeof listing.owner === 'string' && listing.owner === currUser._id.toString()))) || (currUser.isAdmin) ) ) { %>
        <div class="ary_edit_btn">
            <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark ">Edit </a>
            <br><br>
            <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
                <button class="btn btn-dark">Delete </button>
            </form>
            </div>
         
        <hr />        <% } else if (currUser && currUser.isAdmin) { %>
        <div class="ary_edit_btn">
            <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE" onsubmit="return confirm('Are you sure? This will delete this listing.');">
                <button class="btn btn-danger">Delete (Admin)</button>
            </form>
        </div>
        <hr />        <% } %>
        <div class="col-8 offset-3 mb-3">
        


            <% if(currUser){ %>
            <h4 >Leave a Review</h4>
            <form action="/listings/<%= listing.id %>/reviews" 
                method="POST" 
                class="needs-validation" 
                novalidate>
                <!-- <div class="mb-3 mt-3">
                    <label for="rating" class="form-label">Rating</label>
                    <input
                     type="range" 
                     min="1" 
                     max="5" 
                     id="rating" 
                     name="review[rating]" 
                     class="form-range">
                </div>
                <div class="mb-3 mt-3"> -->
<label for="rating" class="form-label">Rating</label>
<fieldset class="starability-slot">
     
  <input 
  type="radio" 
  id="no-rate" 
  class="input-no-rate" 
  name="review[rating]" 
  value="1" 
  checked aria-label="No rating." 
  />
  <input
   type="radio" 
   id="first-rate1" 
   name="review[rating]" 
   value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input 
  type="radio" 
  id="first-rate2"
  name="review[rating]" 
  value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input 
  type="radio" 
  id="first-rate3" 
  name="review[rating]" 
  value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input
  type="radio" 
  id="first-rate4" 
  name="review[rating]" 
  value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input 
  type="radio" 
  id="first-rate5" 
  name="review[rating]" 
  value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
</div>



                <div class="mb-3 mt-3">
                    <label for="comment" class="form-label" >Comments</label>
                    <textarea 
                    name="review[comment]" 
                    id="comment" 
                    cols="12" 
                    rows="5" 
                    class="form-control"
                    required
                    ></textarea>
                    <div class="invalid-feedback">Please add some comments for review</div>
                </div>
                <button class="btn btn-outline-dark">Submit</button>
                <% } %>
            </form>
            <script>
                (function() {
                    'use strict';
                    window.addEventListener('load', function() {
                        let forms = document.querySelectorAll('.needs-validation');
                        Array.prototype.slice.call(forms).forEach(function(form) {
                            form.addEventListener('submit', function(event) {
                                if (form.checkValidity() === false) {
                                    event.preventDefault();
                                    event.stopPropagation();
                                }
                                form.classList.add('was-validated');
                            }, false);
                        });
                    }, false);
                })();
            </script>
            <hr />
           <p><b> All Reviews</b></p>
           <div class="row">
            <% if (listing.reviews && listing.reviews.length) { %>
                <% for (let review of listing.reviews) { %>
                <div class="card col-5 ms-3 mb-3">
                    <h5 class="card-title">@<%= (review.auther && review.auther.username) ? review.auther.username : ((review.auther && review.auther.email) ? review.auther.email : 'User') %></h5>
                                        <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>

                    <p class="card-text"><%= review.comment %></p>
               
                <form class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id%>?_method=DELETE">
                    <button class="btn btn-sm btn-dark">Delete</button>
                </form>
                 </div>
                <% } %>
            <% } else { %>
                <p class="ms-3">No reviews yet.</p>
            <% } %>
           </div>
        </div>
  
<script>
  // Initialize carousel with proper Bootstrap functionality
  document.addEventListener('DOMContentLoaded', function() {
    const carouselElement = document.getElementById('listingCarousel');
    if(carouselElement) {
      // Create a new Bootstrap carousel instance
      const carousel = new bootstrap.Carousel(carouselElement, {
        interval: 3000,  // Auto-slide every 3 seconds
        wrap: true,      // Loop carousel
        pause: 'hover'   // Pause on hover
      });
    }
  });
</script>      </div>
  