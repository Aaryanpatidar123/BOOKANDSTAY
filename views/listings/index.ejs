<script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click",()=>{
       let taxInfo = document.getElementsByClassName("tax-info");
       for(info of taxInfo){
        if(info.style.display != "inline"){
            info.style.display = "inline";
        }else{
             info.style.display = "none";
        }
       
       }
    });
</script>

<script>
    // Category filtering: show the chosen category section in place (hide others) and scroll to it
    (function(){
        const filters = Array.from(document.querySelectorAll('#filters .filter'));
        const sections = Array.from(document.querySelectorAll('.category-section'));

        function setActive(filterEl){
            filters.forEach(f=>f.classList.remove('active'));
            if(filterEl) filterEl.classList.add('active');
        }

        function showAllSections(){
            sections.forEach(s => s.style.display = 'block');
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function showOnlySection(cat){
            sections.forEach(s => { s.style.display = (s.dataset.cat === cat) ? 'block' : 'none'; });
            // scroll to selected section so it is visible (not the top filters)
            const sec = document.querySelector('.category-section[data-cat="'+cat+'"]');
            if(sec) sec.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        filters.forEach(filter => {
            filter.addEventListener('click', () => {
                const cat = filter.dataset.cat;
                setActive(filter);
                // update URL param without reloading
                const url = new URL(window.location.href);
                if(cat === 'All') url.searchParams.delete('category');
                else url.searchParams.set('category', cat);
                history.replaceState(null, '', url);

                if(cat === 'All'){
                    showAllSections();
                } else {
                    showOnlySection(cat);
                }
            });
        });

        // initialize based on URL param
        const params = new URLSearchParams(window.location.search);
        const initialCat = params.get('category') || 'All';
        const initialFilter = document.querySelector('#filters .filter[data-cat="' + initialCat + '"]') || document.querySelector('#filters .filter[data-cat="All"]');
        setActive(initialFilter);
        if(initialCat === 'All') showAllSections(); else showOnlySection(initialCat);
    })();
</script>