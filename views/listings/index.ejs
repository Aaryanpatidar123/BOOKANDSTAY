    <!-- Single filterable listings grid (top icons control visibility) -->
    <!-- Listings grouped by category -->
    <% for (let cat of categories) { %>
        <section class="category-section mt-4" data-cat="<%= cat %>">
            <h3 class="category-title"><%= cat %> <small class="text-muted">(<%= (listingsByCategory[cat]||[]).length %>)</small></h3>
            <% const catListings = listingsByCategory[cat] || []; %>
            <% if (catListings.length) { %>
                <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
                    <% for (let listing of catListings) { %>
                        <a href="/listings/<%= listing._id%>" class="listing-link">
                            <div class="card col listing-card" data-category="<%= listing.category || 'Trending' %>">
                                <img src="<%= (listing.image && listing.image.url) ? listing.image.url : (typeof listing.image === 'string' ? listing.image : 'https://via.placeholder.com/400x300?text=No+Image') %>"
                                    class="card-img-top" alt="listing_image" style="height:20rem" />
                                <div class="card-img-overlay"></div>
                                <div class="card-body">
                                    <p class="card-text">
                                        <b>
                                            <%= listing.title %>
                                        </b><br />
                                        &#8377;<%= (listing.price != null && listing.price !== '') ? Number(listing.price).toLocaleString('en-IN') : 'N/A' %>/night<i class="tax-info"> &nbsp; &nbsp; +18% GST</i><br />

                                    </p>
                                <p class="listing-category">Category: <span class="cat-val"><%= listing.category || 'Trending' %></span></p>
                                </div>
                            </div>
                        </a>
                    <% } %>
                </div>
            <% } else { %>
                <p class="text-muted">No listings in this category yet.</p>
            <% } %>
        </section>
    <% } %>



