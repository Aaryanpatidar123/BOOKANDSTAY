<% layout('layouts/boilerplate') -%>

<style>
  .admin-dashboard-container {
    background: #f8f9fa;
    min-height: 100vh;
    padding: 30px 0;
  }

  .dashboard-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 30px 25px;
    border-radius: 12px;
    margin-bottom: 30px;
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.2);
  }

  .dashboard-header h2 {
    margin: 0;
    font-size: 2rem;
    font-weight: 700;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
  }

  .stat-card {
    background: white;
    padding: 25px;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    border-left: 5px solid #667eea;
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
  }

  .stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(102, 126, 234, 0.2);
  }

  .stat-card.users {
    border-left-color: #5c7cfa;
  }

  .stat-card.listings {
    border-left-color: #37b24d;
  }

  .stat-card.bookings {
    border-left-color: #ffa94d;
  }

  .stat-icon {
    font-size: 2.5rem;
    margin-bottom: 15px;
    opacity: 0.8;
  }

  .stat-card.users .stat-icon {
    color: #5c7cfa;
  }

  .stat-card.listings .stat-icon {
    color: #37b24d;
  }

  .stat-card.bookings .stat-icon {
    color: #ffa94d;
  }

  .stat-card h5 {
    font-size: 0.95rem;
    color: #666;
    font-weight: 600;
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .stat-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: #333;
    margin-bottom: 12px;
  }

  .stat-link {
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .stat-card.users .stat-link {
    color: #5c7cfa;
  }

  .stat-card.listings .stat-link {
    color: #37b24d;
  }

  .stat-card.bookings .stat-link {
    color: #ffa94d;
  }

  .stat-link:hover {
    gap: 8px;
  }

  .config-section {
    background: white;
    padding: 25px;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  }

  .config-section h4 {
    color: #333;
    font-weight: 700;
    margin-bottom: 20px;
    font-size: 1.2rem;
    border-bottom: 2px solid #667eea;
    padding-bottom: 12px;
  }

  .btn-config {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 10px 20px;
    border: none;
    border-radius: 7px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.2s ease;
    margin-right: 10px;
    margin-bottom: 10px;
    text-decoration: none;
    display: inline-block;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
  }

  .btn-config:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(102, 126, 234, 0.5);
    color: white;
  }

  .btn-email {
    background: linear-gradient(135deg, #5c7cfa 0%, #4c6ef5 100%);
  }

  .btn-payment {
    background: linear-gradient(135deg, #37b24d 0%, #2f9e44 100%);
  }

  .btn-email:hover {
    box-shadow: 0 6px 16px rgba(92, 124, 250, 0.5);
  }

  .btn-payment:hover {
    box-shadow: 0 6px 16px rgba(55, 178, 77, 0.5);
  }

  @media (max-width: 768px) {
    .dashboard-header h2 {
      font-size: 1.5rem;
    }

    .stats-grid {
      grid-template-columns: 1fr;
    }

    .stat-number {
      font-size: 2rem;
    }
  }
</style>

<div class="admin-dashboard-container">
  <div class="container">
    <div class="dashboard-header">
      <h2><i class="fas fa-crown"></i> Admin Dashboard</h2>
    </div>

    <!-- Statistics Cards -->
    <div class="stats-grid">
      <a href="/admin/users" class="stat-card users">
        <div class="stat-icon"><i class="fas fa-users"></i></div>
        <h5>Total Users</h5>
        <div class="stat-number"><%= users %></div>
        <div class="stat-link"><i class="fas fa-arrow-right"></i> Manage users</div>
      </a>

      <a href="/listings" class="stat-card listings">
        <div class="stat-icon"><i class="fas fa-building"></i></div>
        <h5>Total Listings</h5>
        <div class="stat-number"><%= listings %></div>
        <div class="stat-link"><i class="fas fa-arrow-right"></i> View listings</div>
      </a>

      <a href="/admin/bookings" class="stat-card bookings">
        <div class="stat-icon"><i class="fas fa-calendar-check"></i></div>
        <h5>Total Bookings</h5>
        <div class="stat-number"><%= bookings %></div>
        <div class="stat-link"><i class="fas fa-arrow-right"></i> View bookings</div>
      </a>
    </div>

    <!-- Configuration Section -->
    <div class="config-section">
      <h4><i class="fas fa-cog"></i> Configuration</h4>
      <a class="btn-config btn-email" href="/admin/email-config">
        <i class="fas fa-envelope"></i> Email Configuration
      </a>
      <a class="btn-config btn-payment" href="/admin/pay-config">
        <i class="fas fa-credit-card"></i> Payment Configuration
      </a>
    </div>
  </div>
</div>

