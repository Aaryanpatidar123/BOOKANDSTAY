<% layout('layouts/boilerplate') %>
<div class="container my-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card shadow-sm">
        <div class="card-body">
          <h3>Email / SMTP configuration</h3>

          <form method="POST" action="/admin/email-config">
            <h5>SMTP (App Password)</h5>
            <div class="mb-3">
              <label class="form-label">SMTP_HOST</label>
              <input name="smtp_host" class="form-control" value="<%= smtpHost %>" />
            </div>
            <div class="mb-3">
              <label class="form-label">SMTP_PORT</label>
              <input name="smtp_port" class="form-control" value="<%= smtpPort %>" />
            </div>
            <div class="mb-3">
              <label class="form-label">SMTP_USER (sender email)</label>
              <input name="smtp_user" class="form-control" value="<%= smtpUser %>" />
            </div>
            <div class="mb-3 form-check">
              <input type="checkbox" class="form-check-input" id="smtp_secure" name="smtp_secure" <%= smtpSecure ? 'checked' : '' %> />
              <label for="smtp_secure" class="form-check-label">Use secure (true for SSL/TLS)</label>
            </div>
            <div class="mb-3">
              <label class="form-label">SMTP_PASS (App Password)</label>
              <input name="smtp_pass" type="password" class="form-control" />
            </div>

            <h5 class="mt-4">Google OAuth (preferred)</h5>
            <div class="mb-3">
              <label class="form-label">GOOGLE_CLIENT_ID</label>
              <input name="google_client_id" class="form-control" value="<%= googleClientId %>" />
            </div>
            <div class="mb-3">
              <label class="form-label">GOOGLE_CLIENT_SECRET</label>
              <input name="google_client_secret" class="form-control" value="<%= googleClientSecret %>" />
            </div>

            <button class="btn btn-primary">Save to .env</button>
          </form>

          <hr />

          <form method="POST" action="/admin-google-auth" class="d-inline">
            <button class="btn btn-success">Authorize Google</button>
            <% if (googleHasRefresh) { %>
              <span class="badge bg-success ms-2">Google authorized</span>
            <% } %>
          </form>

          <form method="POST" action="/send-test-mail" class="mt-3">
            <div class="input-group">
              <input name="test_email" class="form-control" placeholder="recipient@example.com" />
              <button class="btn btn-outline-primary">Send test email</button>
            </div>
          </form>

        </div>
      </div>
    </div>
  </div>
</div>