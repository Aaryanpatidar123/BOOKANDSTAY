<% layout('layouts/boilerplate') -%>

<style>
  .dashboard-container {
    background: #f8f9fa;
    min-height: 100vh;
    padding: 30px 0;
  }

  .dashboard-header {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 30px 25px;
    border-radius: 12px;
    margin-bottom: 30px;
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.2);
  }

  .dashboard-header h2 {
    margin: 0;
    font-size: 2rem;
    font-weight: 700;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 2px solid #667eea;
  }

  .section-header h4 {
    color: #333;
    font-weight: 700;
    margin: 0;
    font-size: 1.2rem;
  }

  .badge-count {
    background: #667eea;
    color: white;
    padding: 6px 12px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .dashboard-section {
    background: white;
    padding: 25px;
    border-radius: 12px;
    margin-bottom: 25px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  }

  .table {
    margin-bottom: 0;
    font-size: 0.95rem;
  }

  .table thead {
    background: #f8f9fa;
    border-bottom: 2px solid #667eea;
  }

  .table thead th {
    color: #333;
    font-weight: 700;
    border: none;
    padding: 12px 15px;
    text-align: left;
  }

  .table tbody td {
    padding: 12px 15px;
    border-color: #e0e0e0;
    vertical-align: middle;
  }

  .table tbody tr:hover {
    background: #f8f9fa;
  }

  .btn-approve {
    background: linear-gradient(135deg, #51cf66 0%, #37b24d 100%);
    color: white;
    border: none;
    padding: 6px 14px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s ease;
    display: inline-block;
    margin-right: 5px;
  }

  .btn-approve:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(81, 207, 102, 0.3);
  }

  .btn-reject {
    background: linear-gradient(135deg, #ff6b6b 0%, #fa5252 100%);
    color: white;
    border: none;
    padding: 6px 14px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s ease;
    display: inline-block;
  }

  .btn-reject:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 107, 107, 0.3);
  }

  .empty-state {
    text-align: center;
    padding: 40px 20px;
    color: #999;
  }

  .empty-state-icon {
    font-size: 3rem;
    margin-bottom: 15px;
    opacity: 0.5;
  }

  .status-badge {
    padding: 6px 12px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.85rem;
    display: inline-block;
  }

  .status-pending {
    background: #ffd43b;
    color: #333;
  }

  .status-approved {
    background: #51cf66;
    color: white;
  }

  .status-paid {
    background: #51cf66;
    color: white;
  }

  .status-unpaid {
    background: #868e96;
    color: white;
  }

  @media (max-width: 768px) {
    .dashboard-header h2 {
      font-size: 1.5rem;
    }

    .table {
      font-size: 0.85rem;
    }

    .table thead th,
    .table tbody td {
      padding: 8px 10px;
    }
  }
</style>

<div class="dashboard-container">
  <div class="container">
    <div class="dashboard-header">
      <h2><i class="fas fa-tachometer-alt"></i> Owner Dashboard</h2>
    </div>

    <!-- Pending Bookings Section -->
    <div class="dashboard-section">
      <div class="section-header">
        <h4><i class="fas fa-hourglass-start"></i> Pending Bookings</h4>
        <span class="badge-count"><%= pendingBookings ? pendingBookings.length : 0 %></span>
      </div>
      
      <% if (pendingBookings && pendingBookings.length > 0) { %>
        <table class="table">
          <thead>
            <tr>
              <th>Listing</th>
              <th>Guest</th>
              <th>Dates</th>
              <th>Total</th>
              <th>Payment</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% pendingBookings.forEach(b => { %>
              <tr>
                <td><strong><%= b.listing ? b.listing.title : '—' %></strong></td>
                <td><%= b.user ? (b.user.email || b.user.username) : '—' %></td>
                <td><%= b.startDate ? new Date(b.startDate).toDateString() : '—' %> — <%= b.endDate ? new Date(b.endDate).toDateString() : '—' %></td>
                <td><strong>₹<%= b.totalPrice %></strong></td>
                <td><span class="status-badge <%= b.paid ? 'status-paid' : 'status-unpaid' %>"><%= b.paid ? 'Paid' : 'Unpaid' %></span></td>
                <td>
                  <form action="/owner/bookings/<%= b._id %>/approve" method="POST" style="display:inline">
                    <button class="btn-approve"><i class="fas fa-check"></i> Approve</button>
                  </form>
                  <form action="/owner/bookings/<%= b._id %>/reject" method="POST" style="display:inline" onsubmit="return confirm('Reject this booking?');">
                    <button class="btn-reject"><i class="fas fa-times"></i> Reject</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon"><i class="fas fa-inbox"></i></div>
          <p>No pending bookings to review.</p>
        </div>
      <% } %>
    </div>

    <!-- Approved Bookings Section -->
    <div class="dashboard-section">
      <div class="section-header">
        <h4><i class="fas fa-check-circle"></i> Approved Bookings (Awaiting or Completed Payment)</h4>
      </div>
      
      <% if (approvedBookings && approvedBookings.length > 0) { %>
        <table class="table">
          <thead>
            <tr>
              <th>Listing</th>
              <th>Guest</th>
              <th>Dates</th>
              <th>Total</th>
              <th>Payment Status</th>
            </tr>
          </thead>
          <tbody>
            <% approvedBookings.forEach(b => { %>
              <tr>
                <td><strong><%= b.listing ? b.listing.title : '—' %></strong></td>
                <td><%= b.user ? (b.user.email || b.user.username) : '—' %></td>
                <td><%= b.startDate ? new Date(b.startDate).toDateString() : '—' %> — <%= b.endDate ? new Date(b.endDate).toDateString() : '—' %></td>
                <td><strong>₹<%= b.totalPrice %></strong></td>
                <td><span class="status-badge <%= b.paid ? 'status-paid' : 'status-pending' %>"><%= b.paid ? '✓ Paid' : '⏳ Awaiting Payment' %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty-state">
          <div class="empty-state-icon"><i class="fas fa-check-circle"></i></div>
          <p>No approved bookings yet.</p>
        </div>
      <% } %>
    </div>
  </div>
</div>
