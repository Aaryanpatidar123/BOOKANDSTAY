<% layout('layouts/boilerplate')%>
 <div class="row mt-3 mb-3">
    <h1 class="col-6 offset-3">Login</h1>
        <div class="col-6  offset-3">
            <form action="/login" method="POST" class="needs-validation" novalidate>
                <div class="mb-3">
                    <label for="username" class="form-label">Username</label>
                    <input 
                    name="username" 
                    id="username"
                    type="text"
                    class="form-control"
                    required 
                    />
                </div>
                
                <div class="mb-3">
                    <label for="password" class="form-label">password</label>
                    <input 
                    name="password" 
                    id="password"
                    type="password"
                    class="form-control"
                    required 
                    />
                </div>
                <div class="mb-3">
                    <label class="form-label">Login as</label>
                    <div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="role" id="loginRoleUser" value="user" <%= (typeof defaultRole === 'undefined' || defaultRole === 'user') ? 'checked' : '' %> >
                            <label class="form-check-label" for="loginRoleUser">User</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="role" id="loginRoleOwner" value="owner" <%= defaultRole === 'owner' ? 'checked' : '' %> >
                            <label class="form-check-label" for="loginRoleOwner">Owner</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" name="role" id="loginRoleAdmin" value="admin" <%= defaultRole === 'admin' ? 'checked' : '' %> >
                            <label class="form-check-label" for="loginRoleAdmin">Admin</label>
                        </div>
                    </div>
                </div>
<button class="btn btn-success">Login</button>
            </form>
        </div>
 </div>